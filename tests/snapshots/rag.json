{
  "agents": [
    {
      "annotations": [],
      "kind": "agent",
      "memory": null,
      "methods": [
        {
          "annotations": [],
          "body": "let context = act ProductDocs.retrieve(query: question)?\nOk(@answer(question, using: context))",
          "name": "handle",
          "params": [
            {
              "default": null,
              "name": "question",
              "type_str": "Str"
            }
          ],
          "return_type": "Result<Str, AgentError>"
        }
      ],
      "model": "anthropic/claude-4",
      "name": "SupportAgent",
      "tools": [
        "ProductDocs.retrieve",
        "CreateTicket"
      ],
      "workers": null
    }
  ],
  "flows": [],
  "global_security": {
    "approval_gates": [],
    "capabilities": [],
    "max_cost_budget_usd": null,
    "max_token_budget": null
  },
  "imports": [
    {
      "kind": "import",
      "names": [
        "Chunk"
      ],
      "source": "axon:types"
    }
  ],
  "metadata": {},
  "prompts": [],
  "rags": [
    {
      "annotations": [],
      "chunker": "Chunker::sliding(size: 512, overlap: 64)",
      "embedder": "@openai/text-embed-3",
      "kind": "rag",
      "methods": [
        {
          "annotations": [],
          "body": "store.search(embed(query), top_k)\n    |> rerank(query, model: @cohere/rerank-3)\n    |> filter(chunk => chunk.score > 0.72)",
          "name": "retrieve",
          "params": [
            {
              "default": null,
              "name": "query",
              "type_str": "Str"
            },
            {
              "default": "5",
              "name": "top_k",
              "type_str": "Int"
            }
          ],
          "return_type": "List<Chunk>"
        }
      ],
      "name": "ProductDocs",
      "source": "\"./knowledge_base/**/*.md\"",
      "store": "VectorDB::postgres(env.PGVECTOR_URL)"
    }
  ],
  "tools": [
    {
      "annotations": [],
      "body": "http.post(env.TICKET_API, { title, priority })",
      "docstrings": [
        "Creates a support ticket.",
        "Use when product documentation does not answer the user's question."
      ],
      "kind": "tool",
      "name": "CreateTicket",
      "params": [
        {
          "default": null,
          "name": "title",
          "type_str": "Str"
        },
        {
          "default": "\"medium\"",
          "name": "priority",
          "type_str": "\"low\" | \"medium\" | \"high\""
        }
      ],
      "return_type": "Result<Str, ToolError>"
    }
  ],
  "type_aliases": [],
  "version": "0.2.0"
}
