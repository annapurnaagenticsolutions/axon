{
  "agents": [
    {
      "annotations": [],
      "kind": "agent",
      "memory": {
        "kind": "ShortTerm",
        "options": {
          "capacity": "2000"
        }
      },
      "methods": [
        {
          "annotations": [],
          "body": "let df = act ReadCSV(path: csv_path)?\nlet code = @generate(\"Python pandas code to answer: {question}\")\nlet stats = act RunPython(code: code, context: { df })?\nlet chart = act PlotChart(data: df, title: question, chart_type: \"auto\")?\nstore memory.working[\"last_stats\"] = stats\nOk(AnalysisReport { question, findings: [], chart_path: chart })",
          "name": "analyze",
          "params": [
            {
              "default": null,
              "name": "csv_path",
              "type_str": "Str"
            },
            {
              "default": null,
              "name": "question",
              "type_str": "Str"
            }
          ],
          "return_type": "Result<AnalysisReport, AgentError>"
        }
      ],
      "model": "anthropic/claude-4",
      "name": "DataAnalysisAgent",
      "tools": [
        "ReadCSV",
        "RunPython",
        "PlotChart"
      ],
      "workers": null
    }
  ],
  "flows": [],
  "global_security": {
    "approval_gates": [],
    "capabilities": [],
    "max_cost_budget_usd": null,
    "max_token_budget": null
  },
