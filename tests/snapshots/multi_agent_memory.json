          "body": "let fact1 = \"Neural networks are inspired by biological brains\"\n\nlet fact2 = \"Backpropagation was invented in 1986\"\n\nact RememberFact(key: \"nn_bio\", value: fact1)\n\nact RememberFact(key: \"backprop\", value: fact2)\n\nact SendMessage(to: \"Writer\", content: \"Research complete on \" + topic)\n\n\"done\"",
          "name": "research",
          "params": [
            {
              "default": null,
              "name": "topic",
              "type_str": "Str"
            }
          ],
          "return_type": "Str"
        }
      ],
