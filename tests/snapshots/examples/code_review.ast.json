        "body": "think f\"Starting code review for: {file_path}\"\n\nlet code = act ReadFile(file_path: file_path)?\nstore memory.working[\"last_file\"] = file_path\nstore memory.working[\"code_length\"] = len(code)\n\nthink f\"Read {len(code)} characters. Sending to LLM for review...\"\n\nlet review_text = model.complete(ReviewPrompt(code, file_path))\n\nthink \"Review received. Saving to disk...\"\n\nlet output_file = \"review_output.md\"\nact WriteReview(output_path: output_file, review: review_text)?\n\nthink f\"Review saved to {output_file}\"\n\nOk(review_text)",
