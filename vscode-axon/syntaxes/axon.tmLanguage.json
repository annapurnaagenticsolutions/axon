{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AXON",
  "scopeName": "source.axon",
  "fileTypes": [".ax"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#annotations" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.triple-slash.axon",
          "match": "///.*$"
        },
        {
          "name": "comment.block.axon",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.axon",
          "match": "\\b(if|else|match|return|let|go|await|spawn|pause|resume|terminate|send|receive|broadcast|discover|act|think|observe|store)\\b"
        },
        {
          "name": "keyword.declaration.axon",
          "match": "\\b(agent|flow|tool|fn|stage|rag|memory|prompt|import|type|enum)\\b"
        },
        {
          "name": "keyword.other.axon",
          "match": "\\b(model|tools|provider|mock|stream|checkpoint)\\b"
        },
        {
          "name": "constant.language.axon",
          "match": "\\b(true|false|none|null|ok|err)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.axon",
          "match": "\\b(Str|Int|Float|Bool|List|Map|Result|Option|Chan|Stream|Agent|Tool|Error|Any)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.axon",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.axon",
              "match": "\\\\."
            },
            {
              "name": "constant.other.placeholder.axon",
              "match": "\\$\\{[^}]+\\}"
            }
          ]
        },
        {
          "name": "string.quoted.single.axon",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.axon",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.interpolated.axon",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.other.placeholder.axon",
              "match": "\\$\\{[^}]+\\}"
            },
            {
              "name": "constant.character.escape.axon",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.axon",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.axon",
          "match": "(@[a-zA-Z_][a-zA-Z0-9_]*(?:\\/[a-zA-Z_][a-zA-Z0-9_]*)?)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.axon",
          "match": "\\bfn\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.axon" }
          }
        },
        {
          "name": "entity.name.function.axon",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.axon",
          "match": "(->|=>|\\+|-\\*|\\*|/|%|==|!=|<=|>=|<|>|\\?\\.|\\?|\\||\\&|\\+\\+)"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.axon",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
